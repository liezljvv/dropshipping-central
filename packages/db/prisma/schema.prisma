generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum IntegrationStatus {
  PENDING
  CONNECTED
  NOT_CONFIGURED
  AUTH_FAILED
  DEGRADED
  ERROR
  DISCONNECTED
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  RETURNED
  FULFILLED
}

enum FulfillmentJobState {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
}

enum WorkflowRunState {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
}

enum ActorType {
  SYSTEM
  USER
  WORKER
}

enum ProfitabilityAlertSeverity {
  info
  warning
  critical
}

enum ProfitabilityAlertStatus {
  ACTIVE
  RESOLVED
}

enum ProfitabilityAlertEntityType {
  PRODUCT
  ORDER
}

model Integration {
  id                 String                  @id @default(cuid())
  platform           String
  name               String
  status             IntegrationStatus       @default(PENDING)
  metadata           Json?
  lastHeartbeatAt    DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  credentials        IntegrationCredential[]
  orders             Order[]
  fulfillmentJobs    FulfillmentJob[]
  workflowRuns       WorkflowRun[]
  automationPolicies AutomationPolicy[]

  @@index([platform, status])
}

model SupplierIntegration {
  id                String              @id @default(cuid())
  name              String
  provider          String
  status            IntegrationStatus   @default(PENDING)
  configPayload     Json
  capabilities      Json
  lastCatalogSyncAt DateTime?
  lastInventorySyncAt DateTime?
  lastPricingSyncAt DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  fulfillmentJobs   FulfillmentJob[]
  products          Product[]
  syncRuns          SupplierSyncRun[]

  @@index([provider, status])
}

model IntegrationCredential {
  id               String      @id @default(cuid())
  integrationId    String
  credentialType   String
  encryptedSecret  String
  encryptedPayload Json?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  integration      Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([integrationId, credentialType])
}

model Order {
  id               String           @id @default(cuid())
  externalId       String
  integrationId    String?
  sourcePlatform   String
  status           OrderStatus      @default(PENDING)
  totalAmount      Decimal          @db.Decimal(12, 2)
  currency         String
  subtotalRevenue  Decimal          @default(0) @db.Decimal(12, 2)
  shippingRevenue  Decimal          @default(0) @db.Decimal(12, 2)
  totalRevenue     Decimal          @default(0) @db.Decimal(12, 2)
  totalProductCost Decimal?         @db.Decimal(12, 2)
  fulfillmentCost  Decimal?         @db.Decimal(12, 2)
  transactionFee   Decimal?         @db.Decimal(12, 2)
  totalCost        Decimal?         @db.Decimal(12, 2)
  rawPayload       Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  integration      Integration?     @relation(fields: [integrationId], references: [id], onDelete: SetNull)
  fulfillmentJobs  FulfillmentJob[]
  lineItems        OrderLineItem[]

  @@unique([externalId, sourcePlatform])
  @@index([status, sourcePlatform])
}

model Product {
  id                    String               @id @default(cuid())
  supplierIntegrationId String?
  externalId            String?
  sourcePlatform        String?
  sku                   String               @unique
  title                 String
  description           String?
  salePrice             Decimal              @db.Decimal(12, 2)
  costPrice             Decimal?             @db.Decimal(12, 2)
  currency              String
  metadata              Json?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  lineItems             OrderLineItem[]
  supplierIntegration   SupplierIntegration? @relation(fields: [supplierIntegrationId], references: [id], onDelete: SetNull)

  @@index([sourcePlatform, externalId])
  @@index([supplierIntegrationId, updatedAt])
}

model OrderLineItem {
  id            String   @id @default(cuid())
  orderId       String
  productId     String?
  externalId    String?
  sku           String
  title         String
  quantity      Int
  unitSalePrice Decimal  @db.Decimal(12, 2)
  unitCostPrice Decimal? @db.Decimal(12, 2)
  currency      String
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product       Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId, sku])
  @@index([productId])
}

model FulfillmentJob {
  id                String              @id @default(cuid())
  orderId           String
  integrationId     String?
  supplierIntegrationId String?
  supplierReference String?
  supplierOrderId   String?
  state             FulfillmentJobState @default(PENDING)
  attemptCount      Int                 @default(0)
  retryable         Boolean             @default(false)
  errorMessage      String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  integration       Integration?        @relation(fields: [integrationId], references: [id], onDelete: SetNull)
  supplierIntegration SupplierIntegration? @relation(fields: [supplierIntegrationId], references: [id], onDelete: SetNull)
  order             Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([state, integrationId])
  @@index([state, supplierIntegrationId])
}

model SupplierSyncRun {
  id                   String            @id @default(cuid())
  supplierIntegrationId String
  syncType             String
  state                WorkflowRunState  @default(QUEUED)
  itemCount            Int               @default(0)
  errorMessage         String?
  startedAt            DateTime?
  finishedAt           DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  supplierIntegration  SupplierIntegration @relation(fields: [supplierIntegrationId], references: [id], onDelete: Cascade)

  @@index([supplierIntegrationId, syncType, state])
}

model WorkflowRun {
  id             String           @id @default(cuid())
  integrationId  String?
  workflowType   String
  state          WorkflowRunState @default(QUEUED)
  startedAt      DateTime?
  finishedAt     DateTime?
  contextPayload Json?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  integration    Integration?     @relation(fields: [integrationId], references: [id], onDelete: SetNull)

  @@index([workflowType, state])
}

model AutomationPolicy {
  id            String       @id @default(cuid())
  integrationId String?
  key           String       @unique
  enabled       Boolean      @default(true)
  configPayload Json?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  integration   Integration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)
}

model AuditEvent {
  id         String    @id @default(cuid())
  actorType  ActorType
  actorId    String?
  eventType  String
  entityType String
  entityId   String
  payload    Json?
  createdAt  DateTime  @default(now())

  @@index([entityType, entityId])
  @@index([eventType, createdAt])
}

model ProfitabilityAlert {
  id              String                       @id @default(cuid())
  entityType      ProfitabilityAlertEntityType
  entityId        String
  ruleCode        String
  ruleName        String
  severity        ProfitabilityAlertSeverity
  status          ProfitabilityAlertStatus    @default(ACTIVE)
  message         String
  metrics         Json
  firstDetectedAt DateTime                     @default(now())
  lastEvaluatedAt DateTime                     @default(now())
  resolvedAt      DateTime?
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt

  @@unique([entityType, entityId, ruleCode])
  @@index([status, severity, entityType])
}
